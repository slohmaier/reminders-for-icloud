<Window x:Class="RemindersForICloud.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Reminders for iCloud"
        Icon="icon.ico"
        Height="800" Width="1100"
        MinHeight="400" MinWidth="600"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E"
        AutomationProperties.Name="Reminders for iCloud"
        AutomationProperties.HelpText="Wrapper window for the iCloud Reminders web application">
    <Grid>
        <wv2:WebView2 x:Name="WebView"
                      AutomationProperties.Name="iCloud Reminders"
                      AutomationProperties.HelpText="iCloud Reminders web interface. Use Tab to navigate, F5 to reload."
                      DefaultBackgroundColor="Black"/>
    </Grid>
</Window>
